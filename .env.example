# Offline mode is the default and is sufficient for tests and the demo.
REPOPILOT_PROVIDER=deterministic

# OpenAI-compatible provider. Never commit the real key.
REPOPILOT_LLM_BASE_URL=
REPOPILOT_LLM_API_KEY=
REPOPILOT_LLM_MODEL=
REPOPILOT_LLM_TIMEOUT_SECONDS=45
REPOPILOT_LLM_MAX_ATTEMPTS=3

# SQLite is the default both locally and in Docker Compose.
# PostgreSQL is optional when the postgres extra and an external server are configured.
REPOPILOT_DATABASE_URL=sqlite+aiosqlite:///./data/repopilot.db
REPOPILOT_REDIS_URL=

# Security and runtime limits.
REPOPILOT_WORKSPACE_ROOT=.
REPOPILOT_API_TOKEN=
REPOPILOT_MAX_STEPS=12
REPOPILOT_MAX_TOOL_CALLS=40
REPOPILOT_MAX_TOTAL_TOKENS=100000
REPOPILOT_MAX_REVIEW_ROUNDS=2
REPOPILOT_TOOL_TIMEOUT_SECONDS=20
REPOPILOT_TOOL_MAX_ATTEMPTS=2
REPOPILOT_TOOL_RETRY_BASE_SECONDS=0.1
REPOPILOT_MAX_UPLOAD_BYTES=10485760
REPOPILOT_ALLOWED_FETCH_HOSTS=
REPOPILOT_LOG_LEVEL=INFO
