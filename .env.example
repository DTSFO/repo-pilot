# Offline mode is the default and is sufficient for tests and the demo.
REPOPILOT_PROVIDER=deterministic

# OpenAI-compatible provider. Never commit the real key.
REPOPILOT_LLM_BASE_URL=
REPOPILOT_LLM_API_KEY=
REPOPILOT_LLM_MODEL=
# Optional legacy aggregate timeout. Phase-specific values take precedence.
REPOPILOT_LLM_TIMEOUT_SECONDS=
REPOPILOT_LLM_CONNECT_TIMEOUT_SECONDS=10
REPOPILOT_LLM_READ_TIMEOUT_SECONDS=120
REPOPILOT_LLM_WRITE_TIMEOUT_SECONDS=30
REPOPILOT_LLM_POOL_TIMEOUT_SECONDS=10
# Upstream Provider SSE is buffered and schema-validated into one ModelResponse; token deltas are
# not exposed as the task report. Disable only for endpoints that cannot accept stream=true.
REPOPILOT_LLM_STREAMING_ENABLED=true
# Disable when a compatible endpoint rejects stream_options.include_usage. Missing usage is then
# conservatively estimated and marked usage_estimated=true in content-free lifecycle telemetry.
REPOPILOT_LLM_STREAM_INCLUDE_USAGE=true
# Persistent provider.request.progress cadence while waiting for first byte or receiving chunks.
REPOPILOT_LLM_STREAM_PROGRESS_INTERVAL_SECONDS=5
REPOPILOT_LLM_MAX_ATTEMPTS=3

# SQLite is the default both locally and in Docker Compose.
# PostgreSQL is optional when the postgres extra and an external server are configured.
REPOPILOT_DATABASE_URL=sqlite+aiosqlite:///./data/repopilot.db
REPOPILOT_REDIS_URL=

# Security and runtime limits.
# Docker Compose binds to loopback by default. Set a non-loopback address only behind TLS and with
# a high-entropy REPOPILOT_API_TOKEN.
REPOPILOT_BIND_ADDRESS=127.0.0.1
REPOPILOT_WORKSPACE_ROOT=.
# Persistent repository registry. Local onboarding is restricted to these roots.
REPOPILOT_REPOSITORY_ROOT=./data/repositories
REPOPILOT_ALLOWED_REPOSITORY_ROOTS=.
REPOPILOT_REPOSITORY_SYNC_TIMEOUT_SECONDS=120
REPOPILOT_API_TOKEN=
# Set to a positive value for a persistent per-client daily POST /api/tasks quota; 0 means unlimited.
REPOPILOT_DAILY_TASK_LIMIT=0
REPOPILOT_DAILY_QUOTA_TIMEZONE=UTC
REPOPILOT_MAX_STEPS=12
REPOPILOT_MAX_TOOL_CALLS=40
REPOPILOT_MAX_TOTAL_TOKENS=100000
REPOPILOT_MAX_REVIEW_ROUNDS=2
REPOPILOT_TOOL_TIMEOUT_SECONDS=20
REPOPILOT_TOOL_MAX_ATTEMPTS=2
REPOPILOT_TOOL_RETRY_BASE_SECONDS=0.1
REPOPILOT_MAX_UPLOAD_BYTES=10485760
REPOPILOT_ALLOWED_FETCH_HOSTS=
# Task SSE polls durable SQLite events; heartbeat is a non-persistent transport comment and is
# distinct from provider.request.progress, which describes the upstream model request.
REPOPILOT_SSE_POLL_SECONDS=0.2
REPOPILOT_SSE_HEARTBEAT_SECONDS=15
REPOPILOT_LOG_LEVEL=INFO
